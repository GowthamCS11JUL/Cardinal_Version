TIMER2.$name               = "TIMER_2";
TIMER2.timerClkPrescale    = 32;
TIMER2.interrupts          = ["ZERO"];
TIMER2.timerMode           = "PERIODIC_UP";
TIMER2.timerPeriod         = "65.535 ms";
