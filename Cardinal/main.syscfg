SPI1.$name                      = "SPI_0";
SPI1.targetBitRate              = 1000000;
SPI1.enableDMAEvent1            = false;
SPI1.enableDMAEvent2            = false;
SPI1.dataSize                   = 16;
SPI1.enabledInterrupts          = ["IDLE","RX","TX"];
SPI1.chipSelect                 = ["2"];
SPI1.overrideRetention          = true;
